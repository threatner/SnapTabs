{
  "name": "snaptabs",
  "version": "1.3.0",
  "description": "Chrome extension to snapshot and restore browser tabs, with tab groups, incognito, session manager, live recording, and crash-safe auto-save.",
  "private": true,
  "type": "module",
  "author": "Rahul Chaudhary <rc22.rahul@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/threatner/SnapTabs",
  "repository": {
    "type": "git",
    "url": "https://github.com/threatner/SnapTabs.git"
  },
  "keywords": [
    "chrome-extension",
    "tab-manager",
    "session-manager",
    "tab-groups",
    "incognito",
    "tab-saver",
    "browser-tabs",
    "snapshot",
    "restore-tabs",
    "productivity"
  ],
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "postinstall": "wxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:debug": "playwright test --config=e2e/playwright.config.ts --debug"
  },
  "dependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@wxt-dev/module-svelte": "^2.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0",
    "wxt": "^0.19.0"
  }
}
